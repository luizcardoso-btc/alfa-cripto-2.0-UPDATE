/* ══════════════════════════════════════════════
   ALFA CRIPTO SINAIS — style.css
   Dark cyberpunk green · Rajdhani + Share Tech Mono
   ══════════════════════════════════════════════ */

/* ── TOKENS ── */
:root {
  --bg:       #060a06;
  --bg2:      #0a0f0a;
  --bg3:      #0d1f0d;
  --bg4:      #0a150a;
  --border:   #1a2a1a;
  --border2:  #2a3a2a;
  --green:    #00ff88;
  --green2:   #00cc55;
  --green-dim:#00ff8820;
  --green-bd: #00ff8840;
  --red:      #ff4466;
  --red-dim:  #ff446620;
  --red-bd:   #ff446640;
  --gold:     #FFD700;
  --orange:   #F7931A;
  --purple:   #627EEA;
  --yellow:   #ffaa00;
  --text:     #e8f4e8;
  --text2:    #aabbaa;
  --text3:    #778877;
  --text4:    #556655;
  --text5:    #334433;
  --text6:    #1a2a1a;
  --font-head:"Rajdhani", sans-serif;
  --font-body:"Barlow", sans-serif;
  --font-mono:"Share Tech Mono", monospace;
  --radius:   12px;
  --radius-sm:8px;
  --radius-xs:6px;
  --max-w:    430px;
  --nav-h:    62px;
  --header-h: 0px; /* set by JS */
}

/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
}
button { cursor: pointer; font-family: var(--font-head); }
input, select, textarea {
  font-family: var(--font-body);
  color: var(--text);
  outline: none;
}
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--green); border-radius: 2px; }

/* ── APP SHELL ── */
#app {
  max-width: var(--max-w);
  margin: 0 auto;
  height: 100dvh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* ══ HEADER ══ */
#header {
  background: linear-gradient(180deg, #0b180b 0%, var(--bg) 100%);
  border-bottom: 1px solid var(--border);
  padding: 13px 14px 0;
  flex-shrink: 0;
  z-index: 90;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 9px;
}

.brand { display: flex; align-items: center; gap: 10px; }
.brand-icon {
  width: 40px; height: 40px;
  background: linear-gradient(135deg, var(--green), var(--green2));
  border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-head);
  font-size: 22px; font-weight: 900; color: #000;
  box-shadow: 0 0 14px #00ff8850;
}
.brand-name { display: block; font-family: var(--font-head); font-size: 16px; font-weight: 700; color: #fff; letter-spacing: 1.5px; }
.brand-sub  { display: block; font-family: var(--font-mono); font-size: 9px; color: var(--green); letter-spacing: 3px; }

.header-actions { display: flex; align-items: center; gap: 7px; }
.live-badge {
  background: var(--bg3);
  border: 1px solid var(--green-bd);
  border-radius: var(--radius-sm);
  padding: 4px 9px;
  display: flex; align-items: center; gap: 5px;
  font-family: var(--font-mono); font-size: 10px; color: var(--green);
}
.pulse-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  animation: pulse 1.4s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.2} }

.refresh-btn {
  width: 32px; height: 32px;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--green); font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: transform .35s, opacity .2s;
}
.refresh-btn:hover { transform: rotate(180deg); }
.refresh-btn:disabled { opacity: .35; }

#btnLogout { color: var(--text4); }
#btnLogout:hover { transform: none; color: var(--red); border-color: var(--red-bd); }

/* ── Ticker ── */
.ticker-bar {
  background: var(--bg4);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 5px 12px;
  overflow: hidden;
  margin-bottom: 9px;
}
.ticker-text {
  font-family: var(--font-mono); font-size: 11px;
  animation: tickIn .35s ease;
}
@keyframes tickIn { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:translateY(0)} }
.ticker-up   { color: var(--green); }
.ticker-down { color: var(--red); }

/* ── Scan Progress ── */
.scan-wrap { margin-bottom: 9px; }
.scan-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
.scan-label { font-family: var(--font-mono); font-size: 10px; color: var(--green); }
.scan-pct   { font-family: var(--font-mono); font-size: 10px; color: var(--green); }
.scan-track { background: var(--border); border-radius: 3px; height: 4px; }
.scan-bar {
  height: 4px; width: 0%; border-radius: 3px;
  background: linear-gradient(90deg, var(--green), var(--green2));
  box-shadow: 0 0 8px #00ff8855;
  transition: width .4s ease;
}

/* ── Market Mini-bar ── */
.market-mini {
  display: flex; gap: 6px;
  margin-bottom: 9px;
}
.mini-card {
  flex: 1;
  background: var(--bg4); border: 1px solid var(--border);
  border-radius: 9px; padding: 6px 9px;
}
.mini-cd { flex: 0 0 auto; min-width: 58px; text-align: center; }
.mini-label { display: block; font-family: var(--font-mono); font-size: 9px; color: var(--text4); margin-bottom: 2px; }
.mini-val   { display: block; font-family: var(--font-head); font-size: 13px; font-weight: 700; color: #fff; }
.mini-val.mono { font-family: var(--font-mono); }

/* ── Stats Row ── */
.stats-row { display: flex; gap: 6px; margin-bottom: 9px; }
.stat-card {
  flex: 1;
  background: linear-gradient(135deg, var(--bg3), var(--bg4));
  border: 1px solid var(--border);
  border-radius: 10px; padding: 6px 8px; text-align: center;
}
.stat-val   { display: block; font-family: var(--font-head); font-size: 18px; font-weight: 700; color: #fff; }
.stat-val.green { color: var(--green); }
.stat-label { display: block; font-family: var(--font-body); font-size: 9px; color: var(--text4); letter-spacing: 1px; margin-top: 1px; }

/* ── Tabs ── */
.tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
}
.tab-btn {
  flex: 1;
  background: none; border: none;
  border-bottom: 2px solid transparent;
  padding: 7px 0;
  font-family: var(--font-head); font-size: 11px; font-weight: 700;
  color: var(--text5); letter-spacing: .5px;
  transition: color .15s, border-color .15s;
}
.tab-btn.active { color: var(--green); border-bottom-color: var(--green); }

/* ══ MAIN / PANELS ══ */
#main {
  flex: 1;
  overflow: hidden;
  position: relative;
}
.panel {
  display: none;
  height: 100%;
  overflow-y: auto;
  padding: 12px 12px 80px;
}
.panel.active { display: block; }

/* ── Add Manual Button ── */
.add-manual-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--bg3), var(--bg4));
  border: 1px dashed var(--green-bd);
  border-radius: var(--radius);
  padding: 11px 0;
  margin-bottom: 12px;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  color: var(--green); font-size: 13px; font-weight: 700; letter-spacing: 1px;
  transition: background .2s, border-color .2s;
}
.add-manual-btn:hover { background: var(--green-dim); border-color: var(--green); }
.plus-icon { font-size: 18px; }

/* ── Signal Cards ── */
.signal-card {
  border-radius: 14px; padding: 13px;
  margin-bottom: 9px;
  border: 1px solid var(--border);
  background: var(--bg2);
  transition: transform .15s, border-color .2s;
}
.signal-card:hover { transform: translateY(-1px); }

.signal-card.profit  { background: linear-gradient(135deg,#091509,#060e06); border-color: #00ff8835 !important; }
.signal-card.active  { background: #0a0f0a; border-color: rgba(255,255,255,.07); }
.signal-card.manual  { background: #0a0c0a; border-color: var(--green-dim); }
.signal-card.short   { background: linear-gradient(135deg,#150909,#0e0606); border-color: #ff446630; }

.sc-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px; }
.sc-pair {
  font-family: var(--font-head); font-size: 15px; font-weight: 700; letter-spacing: 1px;
}
.sc-pair.long  { color: var(--green); }
.sc-pair.short { color: var(--red); }
.sc-meta { font-family: var(--font-mono); font-size: 9px; color: var(--text5); margin-top: 2px; }

.sc-right { display:flex; flex-direction:column; align-items:flex-end; gap:4px; }

/* Type badge */
.type-badge {
  display: inline-block;
  border-radius: var(--radius-xs); padding: 3px 10px;
  font-family: var(--font-head); font-size: 11px; font-weight: 700; letter-spacing: 1px;
}
.type-badge.long  { background:var(--green-dim); color:var(--green); border:1px solid var(--green-bd); }
.type-badge.short { background:var(--red-dim); color:var(--red); border:1px solid var(--red-bd); }

/* Manual tag */
.manual-tag {
  display: inline-block;
  background: rgba(255,255,255,.1); color: #888;
  border: 1px solid rgba(255,255,255,.15);
  border-radius: 5px; padding: 1px 6px;
  font-family: var(--font-mono); font-size: 9px;
  margin-left: 6px; vertical-align: middle;
}

/* Stars */
.stars { font-size: 11px; letter-spacing: 1px; }
.star-on  { color: var(--gold); }
.star-off { color: #1a2a1a; }

/* Data row */
.sc-data { display:flex; gap:14px; margin-bottom:8px; }
.sc-field label { display:block; font-family:var(--font-mono); font-size:9px; color:var(--text4); margin-bottom:1px; }
.sc-field span  { font-family:var(--font-mono); font-size:12px; color:#fff; }
.sc-field span.bold { font-family:var(--font-head); font-weight:700; }

/* Setup badge */
.setup-badge {
  display: inline-block;
  background: #00ff8812; color: var(--green);
  border: 1px solid #00ff8825;
  border-radius: var(--radius-xs); padding: 2px 7px;
  font-family: var(--font-mono); font-size: 10px;
  margin-bottom: 7px;
}

/* Reason box */
.sc-reason {
  font-size: 11px; color: var(--text4);
  font-family: var(--font-body); line-height: 1.45;
  padding: 6px 9px;
  background: #0d1a0d;
  border-radius: var(--radius-sm);
  border-left: 2px solid var(--green-bd);
  margin-bottom: 8px;
}
.sc-reason.manual { border-left-color: rgba(255,255,255,.15); }

/* Targets */
.sc-targets-label { font-family:var(--font-mono); font-size:10px; color:var(--text4); margin-bottom:5px; }
.targets-wrap { display:flex; flex-wrap:wrap; gap:3px; }
.pill {
  padding: 3px 7px; border-radius: 20px;
  font-family: var(--font-mono); font-size: 10px;
  transition: background .2s;
}
.pill-hit   { background:var(--green); color:#000; font-weight:700; }
.pill-hit-s { background:var(--red); color:#fff; font-weight:700; }
.pill-active{ background:var(--green-dim); color:var(--green); border:1px solid var(--green-bd); }
.pill-miss  { background:#111d11; color:#2a3a2a; border:1px solid #1a2a1a; }

/* SL / progress footer */
.sc-footer { font-family:var(--font-mono); font-size:10px; color:var(--text5); margin-top:8px; }

/* Profit card specifics */
.profit-label { font-family:var(--font-mono); font-size:10px; color:#00ff88aa; letter-spacing:1px; }
.profit-sub   { font-size:10px; color:var(--text5); margin-top:1px; }
.profit-pct {
  font-family: var(--font-head); font-size: 30px; font-weight: 700;
  color: var(--green); letter-spacing: 1px; margin-top: 3px;
  text-shadow: 0 0 18px #00ff8888;
}
.profit-pct.loss { color:var(--red); text-shadow:0 0 18px #ff446688; }
.profit-time { font-family:var(--font-mono); font-size:11px; color:var(--text4); }
.profit-check {
  width:26px; height:26px;
  background:var(--green); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:13px; font-weight:700; color:#000;
}

/* Empty state */
.empty-state { text-align:center; padding:40px 20px; }
.empty-icon  { font-size:40px; margin-bottom:10px; }
.empty-title { font-family:var(--font-head); font-size:15px; letter-spacing:1px; color:var(--text4); margin-bottom:16px; }
.primary-btn {
  background: linear-gradient(135deg, var(--green), var(--green2));
  border: none; border-radius: 10px;
  padding: 10px 24px;
  font-family: var(--font-head); font-weight: 700; font-size: 13px;
  color: #000; letter-spacing: 1px;
  transition: opacity .2s;
}
.primary-btn:hover { opacity: .85; }

/* Market note */
.market-note-box {
  background: var(--bg4); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 11px 13px; margin-top: 4px;
}
.note-label { font-family:var(--font-mono); font-size:10px; color:var(--green); margin-bottom:4px; }
.note-text  { font-size:12px; color:var(--text3); font-family:var(--font-body); line-height:1.5; }

/* ════════════════════════
   MERCADO TAB
   ════════════════════════ */
.section-title {
  font-family: var(--font-mono); font-size: 10px;
  color: var(--text4); letter-spacing: 2px;
  margin-bottom: 9px;
}

/* Macro grid */
.macro-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
.macro-card {
  background: linear-gradient(135deg, var(--bg3), var(--bg4));
  border: 1px solid var(--border);
  border-radius: 11px; padding: 11px 12px;
}
.macro-icon  { font-size:16px; margin-bottom:4px; }
.macro-val   { font-family:var(--font-head); font-size:16px; font-weight:700; color:#fff; }
.macro-label { font-size:10px; color:var(--text4); font-family:var(--font-body); margin-top:2px; }

/* Bias card */
.bias-card {
  background: linear-gradient(135deg, var(--bg3), var(--bg4));
  border-radius: var(--radius); padding: 13px 14px; margin-bottom: 14px;
}
.bias-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
.bias-lbl { font-family:var(--font-mono); font-size:12px; color:var(--text4); letter-spacing:1px; }
.bias-badge {
  border-radius: var(--radius-xs); padding: 3px 10px;
  font-family: var(--font-head); font-size: 11px; font-weight: 700; letter-spacing: 1px;
}
.bias-BULLISH { background:var(--green-dim); color:var(--green); border:1px solid var(--green-bd); }
.bias-BEARISH { background:var(--red-dim); color:var(--red); border:1px solid var(--red-bd); }
.bias-NEUTRO  { background:#ffaa0020; color:var(--yellow); border:1px solid #ffaa0040; }

/* Fear & Greed */
.fg-wrap { margin-bottom: 8px; }
.fg-labels { display:flex; justify-content:space-between; margin-bottom:4px; }
.fg-lbl { font-family:var(--font-mono); font-size:9px; color:var(--text4); }
.fg-track {
  background: var(--border); border-radius: 5px; height: 8px;
  position: relative; overflow: visible; margin-bottom: 6px;
}
.fg-gradient {
  position:absolute; inset:0;
  background: linear-gradient(90deg, var(--red), var(--yellow), var(--green));
  border-radius: 5px; opacity:.4;
}
.fg-needle {
  position:absolute; top:-3px;
  width:14px; height:14px;
  background:#fff; border-radius:50%;
  transform: translateX(-50%);
  border: 2px solid var(--green);
  box-shadow: 0 0 8px #00ff8888;
  transition: left .8s ease;
}
.fg-val-row { text-align:center; }
.fg-val  { font-family:var(--font-head); font-size:22px; font-weight:700; }
.fg-desc { font-size:11px; color:var(--text3); font-family:var(--font-body); margin-left:6px; }

/* Chart card */
.chart-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 13px 12px; margin-bottom: 14px;
}
.chart-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 10px;
}
.chart-title { font-family:var(--font-head); font-size:13px; font-weight:700; color:#fff; letter-spacing:1px; }
.chart-price { font-family:var(--font-mono); font-size:11px; color:var(--green); }
.chart-legend { display:flex; gap:12px; margin-bottom:8px; }
.legend-item { display:flex; align-items:center; gap:4px; }
.legend-dot  { width:8px; height:8px; border-radius:2px; }
.legend-lbl  { font-family:var(--font-mono); font-size:9px; color:var(--text4); }
canvas { display:block; width:100% !important; }

/* Sectors */
.sectors-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
.sector-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 10px; padding: 9px 11px;
}
.sector-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; }
.sector-name  { font-family:var(--font-head); font-size:11px; font-weight:700; color:#ccc; }
.sector-score { font-family:var(--font-mono); font-size:10px; }
.sector-track { background:var(--border); border-radius:3px; height:4px; margin-bottom:5px; }
.sector-bar   { height:4px; border-radius:3px; transition:width 1s ease; }

/* Movers */
.movers-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
.movers-col-title { font-family:var(--font-mono); font-size:10px; letter-spacing:1.5px; margin-bottom:7px; }
.mover-card {
  border-radius: 9px; padding: 8px 10px; margin-bottom: 6px;
  display: flex; justify-content: space-between; align-items: center;
}
.mover-card.up   { background:#091509; border:1px solid #00ff8820; }
.mover-card.dn   { background:#150909; border:1px solid #ff446620; }
.mover-pair { font-family:var(--font-head); font-size:11px; font-weight:700; color:#ccc; }
.mover-right { text-align:right; }
.mover-chg  { font-family:var(--font-head); font-size:12px; font-weight:700; }
.mover-price{ font-family:var(--font-mono); font-size:9px; color:var(--text5); }

/* Key Levels */
.levels-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
.level-card {
  background: #060a06; border-radius: 9px; padding: 9px 11px;
}
.level-lbl { font-family:var(--font-mono); font-size:9px; color:var(--text4); margin-bottom:3px; }
.level-val { font-family:var(--font-mono); font-size:14px; font-weight:700; }

.update-btn {
  width: 100%;
  background: var(--bg3); border: 1px solid var(--green-bd);
  border-radius: 10px; padding: 11px 0;
  color: var(--green); font-family:var(--font-head);
  font-size: 13px; font-weight: 700; letter-spacing: 1px;
  transition: background .2s;
}
.update-btn:hover { background: var(--green-dim); }

/* ════════════════════════
   SINAIS TAB
   ════════════════════════ */
.filter-row { display:flex; gap:6px; margin-bottom:12px; }
.filter-btn {
  flex: 1; padding: 8px 0; border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--bg2);
  color: var(--text5); font-weight:700; font-size:12px;
  font-family: var(--font-head); letter-spacing:1px;
  transition: all .15s;
}
.filter-btn.active {
  background: var(--green-dim); color: var(--green);
  border-color: var(--green-bd);
}

.perf-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:7px; margin-bottom:14px; }
.perf-card {
  background: linear-gradient(135deg,var(--bg3),var(--bg4));
  border: 1px solid var(--border);
  border-radius: 10px; padding: 9px 7px; text-align:center;
}
.perf-val   { display:block; font-family:var(--font-head); font-size:18px; font-weight:700; color:#fff; }
.perf-val.green { color:var(--green); }
.perf-label { display:block; font-family:var(--font-body); font-size:9px; color:var(--text4); }
.perf-sub   { display:block; font-family:var(--font-mono); font-size:9px; color:var(--text5); margin-top:1px; }

.signal-row {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 11px 13px; margin-bottom:8px;
  display: flex; justify-content:space-between; align-items:center;
  transition: border-color .2s;
}
.signal-row.profit { border-color:#00ff8825; }
.signal-row-left .row-pair { font-family:var(--font-head); font-size:14px; font-weight:700; color:#fff; }
.signal-row-left .row-meta { font-family:var(--font-mono); font-size:10px; color:var(--text4); margin-top:1px; }
.signal-row-right { text-align:right; }
.row-profit { font-family:var(--font-head); font-size:15px; font-weight:700; color:var(--green); margin-top:4px; }
.row-prog   { font-family:var(--font-mono); font-size:10px; color:var(--text4); margin-top:4px; }
.m-tag { background:rgba(255,255,255,.1); color:#888; border:1px solid rgba(255,255,255,.15); border-radius:4px; padding:1px 5px; font-family:var(--font-mono); font-size:8px; margin-left:5px; vertical-align:middle; }

/* ════════════════════════
   EDUCAÇÃO TAB
   ════════════════════════ */
.edu-header { font-family:var(--font-mono); font-size:10px; color:var(--text4); letter-spacing:2px; margin-bottom:12px; }
.lesson-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 13px 14px; margin-bottom:8px;
  display: flex; justify-content:space-between; align-items:center;
  transition: background .15s, border-color .15s;
  cursor: pointer;
}
.lesson-card:hover { background:var(--bg3); border-color:var(--green-bd); }
.lesson-left { display:flex; align-items:center; gap:12px; }
.lesson-icon {
  width:38px; height:38px;
  background:var(--bg3); border:1px solid var(--border);
  border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  font-size:18px; flex-shrink:0;
}
.lesson-num   { font-family:var(--font-mono); font-size:9px; color:var(--green); letter-spacing:1.5px; margin-bottom:2px; }
.lesson-title { font-family:var(--font-head); font-size:14px; font-weight:600; color:#fff; }
.lesson-dur   { font-family:var(--font-mono); font-size:10px; color:var(--text4); margin-top:1px; }
.play-btn {
  width:32px; height:32px;
  border:2px solid var(--green); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  color:var(--green); font-size:11px; flex-shrink:0;
  background:none;
}

/* ══ BOTTOM NAV ══ */
.bottom-nav {
  display: flex; justify-content:space-around;
  background: var(--bg);
  border-top: 1px solid var(--border);
  padding: 9px 0 16px;
  flex-shrink: 0;
  z-index: 150;
}
.nav-btn {
  display:flex; flex-direction:column; align-items:center; gap:3px;
  color: var(--text5); background:none; border:none;
  min-width: 65px; position:relative;
  transition: color .15s;
}
.nav-btn.active { color:var(--green); }
.nav-icon  { font-size:20px; }
.nav-label { font-family:var(--font-head); font-size:10px; font-weight:700; letter-spacing:.5px; }
.nav-badge {
  position:absolute; top:-2px; right:8px;
  background:var(--green); color:#000;
  border-radius:50%; width:16px; height:16px;
  font-size:9px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
}

/* ══ CHAT FAB ══ */
.chat-fab {
  position:fixed; bottom:76px; right:16px;
  width:52px; height:52px; border-radius:50%;
  background: linear-gradient(135deg,var(--green),var(--green2));
  border:none; font-size:22px;
  box-shadow: 0 4px 20px #00ff8850;
  display:flex; align-items:center; justify-content:center;
  z-index:100; transition:transform .2s;
}
.chat-fab:hover { transform:scale(1.08); }

/* ══ CHAT PANEL ══ */
.chat-panel {
  position:fixed; bottom:0; left:50%; transform:translateX(-50%);
  width:100%; max-width:var(--max-w);
  height:68vh; background:#080d08;
  border:1px solid var(--border);
  border-radius:20px 20px 0 0;
  display:flex; flex-direction:column;
  z-index:200; box-shadow:0 -10px 50px rgba(0,0,0,.6);
}
.chat-header {
  padding:13px 16px; border-bottom:1px solid var(--border);
  display:flex; justify-content:space-between; align-items:center;
  background:linear-gradient(135deg,var(--bg3),#080d08);
  flex-shrink:0;
}
.chat-brand { display:flex; align-items:center; gap:10px; }
.chat-icon  {
  width:35px; height:35px;
  background:linear-gradient(135deg,var(--green),var(--green2));
  border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:17px;
}
.chat-name { font-family:var(--font-head); font-size:14px; font-weight:700; color:#fff; }
.chat-sub  { font-family:var(--font-mono); font-size:9px; color:var(--green); }
.chat-close {
  background:#1a2a1a; border:none; color:#aaa;
  width:28px; height:28px; border-radius:50%; font-size:15px;
  display:flex; align-items:center; justify-content:center;
}
.chat-messages {
  flex:1; overflow-y:auto; padding:12px 13px;
  display:flex; flex-direction:column; gap:9px;
}
.msg { display:flex; }
.msg-ai   { justify-content:flex-start; }
.msg-user { justify-content:flex-end; }
.bubble {
  max-width:86%; padding:10px 13px; border-radius:16px;
  font-size:13px; line-height:1.55;
  animation:fadeUp .3s ease;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }
.bubble-ai {
  background:var(--bg3); color:var(--text2);
  border:1px solid var(--border);
  font-family:var(--font-body);
}
.bubble-ai strong { color:var(--green); }
.bubble-user {
  background:linear-gradient(135deg,var(--green),var(--green2));
  color:#000; font-family:var(--font-body); font-weight:600;
}
.typing { display:flex; gap:5px; padding:10px 14px; }
.typing-dot {
  width:7px; height:7px; border-radius:50%; background:var(--green);
}
.typing-dot:nth-child(1){animation:pulse .8s infinite;}
.typing-dot:nth-child(2){animation:pulse 1s infinite;}
.typing-dot:nth-child(3){animation:pulse 1.2s infinite;}

.chat-input-row {
  padding:10px 12px 18px; border-top:1px solid var(--border);
  display:flex; gap:7px; flex-shrink:0;
}
.chat-input {
  flex:1; background:var(--bg3); border:1px solid var(--border);
  border-radius:12px; padding:10px 13px;
  color:#fff; font-size:13px; font-family:var(--font-body);
}
.chat-input::placeholder { color:var(--text5); }
.chat-send {
  background:linear-gradient(135deg,var(--green),var(--green2));
  border:none; border-radius:12px; width:44px;
  font-size:17px; color:#000;
  display:flex; align-items:center; justify-content:center;
  transition:opacity .2s;
}
.chat-send:disabled { opacity:.4; }

/* ══ MODAL ══ */
.modal-overlay {
  position:fixed; inset:0; background:rgba(0,0,0,.8);
  z-index:300; display:flex; align-items:flex-end; justify-content:center;
}
.modal {
  width:100%; max-width:var(--max-w);
  background:#080d08; border:1px solid var(--border);
  border-radius:20px 20px 0 0;
  padding:20px 16px 34px;
}
.modal-header {
  display:flex; justify-content:space-between; align-items:center;
  margin-bottom:16px;
}
.modal-title { font-family:var(--font-head); font-size:16px; font-weight:700; color:#fff; letter-spacing:1px; }
.modal-close {
  background:#1a2a1a; border:none; color:#aaa;
  width:28px; height:28px; border-radius:50%; font-size:15px;
  display:flex; align-items:center; justify-content:center;
}
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:8px; }
.form-group { display:flex; flex-direction:column; gap:4px; }
.form-group.full { margin-bottom:8px; }
.form-group label {
  font-family:var(--font-mono); font-size:9px; color:var(--text4);
}
.form-group input,
.form-group select,
.form-group textarea {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:9px; padding:9px 11px;
  color:#fff; font-size:13px; font-family:var(--font-head);
  width:100%;
  transition: border-color .2s;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color:var(--green-bd); }
.form-group select { appearance:none; }
.form-group textarea { resize:none; font-family:var(--font-body); line-height:1.5; }
.submit-btn {
  width:100%; margin-top:6px;
  background:linear-gradient(135deg,var(--green),var(--green2));
  border:none; border-radius:11px; padding:13px 0;
  font-family:var(--font-head); font-weight:700; font-size:15px;
  color:#000; letter-spacing:1px;
  transition:opacity .2s;
}
.submit-btn:hover { opacity:.88; }

/* ── Utility ── */
.green  { color:var(--green) !important; }
.red    { color:var(--red) !important; }
.yellow { color:var(--yellow) !important; }
.mono   { font-family:var(--font-mono) !important; }
.shimmer {
  background:linear-gradient(90deg,#0d1117 25%,#111d11 50%,#0d1117 75%);
  background-size:200% 100%;
  animation:shimmer 1.5s infinite;
  border-radius:var(--radius);
  height:100px; margin-bottom:10px;
}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ── Responsive: desktop preview ── */
@media(min-width:431px){
  #app { box-shadow:0 0 60px rgba(0,255,136,.08); }
  .chat-panel, .modal-overlay .modal { max-width:var(--max-w); left:50%; right:auto; transform:translateX(-50%); }
  .bottom-nav { max-width:var(--max-w); left:50%; transform:translateX(-50%); position:fixed; bottom:0; }
  .chat-fab { right:calc(50% - var(--max-w)/2 + 16px); }
}

/* ══ ADIÇÕES v2 — preços reais + targets progress ══ */
.live-price-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 6px 0 4px;
  padding: 4px 8px;
  background: rgba(0,255,136,0.06);
  border-radius: 6px;
  border: 1px solid rgba(0,255,136,0.12);
}
.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #00ff88;
  box-shadow: 0 0 6px #00ff88;
  animation: pulse-dot 2s infinite;
  flex-shrink: 0;
}
@keyframes pulse-dot {
  0%,100%{opacity:1;transform:scale(1);}
  50%{opacity:.4;transform:scale(.7);}
}
.live-price {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #aaa;
}
.live-price b {
  color: #00ff88;
}
.targets-progress {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #00ff88;
  margin-left: 4px;
}
